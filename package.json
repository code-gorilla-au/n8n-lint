{
	"name": "n8n-lint",
	"version": "1.0.0",
	"description": "Simple tool to lint against workflow JSON Files",
	"homepage": "https://github.com/code-gorilla-au/n8n-lint#readme",
	"bugs": {
		"url": "https://github.com/code-gorilla-au/n8n-lint/issues"
	},
	"engines": {
		"node": ">=24"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/code-gorilla-au/n8n-lint.git"
	},
	"license": "MIT",
	"author": "frag223",
	"type": "module",
	"main": "src/index.ts",
	"imports": {
		"#lib/*": "./src/lib/*",
		"#src/*": "./src/*"
	},
	"scripts": {
		"start": "node --experimental-transform-types src/index.ts",
		"lint": "npx @biomejs/biome check",
		"lint:fix": "npx @biomejs/biome check --write",
		"test": "echo \"Error: no test specified\" && exit 1"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.13",
		"@types/node": "^25.1.0"
	},
	"dependencies": {
		"pino": "^10.3.0",
		"pino-pretty": "^13.1.3"
	}
}
