package rules

import (
	"os"
	"path/filepath"
	"testing"

	"github.com/code-gorilla-au/odize"
)

func TestRule_{{ .Name | caseSnake }}(t *testing.T) {
    group := odize.NewGroup(t, nil)

    cwd, err := os.Getwd()
    odize.AssertNoError(t, err)
    workflowFile := filepath.Join(cwd, "test-data", "no_dangling_ifs.json")

    workflow, err := n8n.LoadWorkflowFromFile(workflowFile)
    odize.AssertNoError(t, err)

    finder := n8n.NewWorkflowTree(workflow)

    err = group.
        Test("should do something", func(t *testing.T) {
			outcome, oErr := rule{{ .Name | casePascal }}.Run(&finder, Ruleset{
				{{ .Name | casePascal }}: {{ .Name | casePascal }}Config{
					BaseRuleConfig: BaseRuleConfig{
						Name:   ruleName{{ .Name | casePascal }},
						Report: ReportError,
					},
				},
			})
			odize.AssertNoError(t, oErr)
        }).
        Run()
    odize.AssertNoError(t, err)
}